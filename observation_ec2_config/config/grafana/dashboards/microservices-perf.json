{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "Microservices Performance — RED+USE Dashboard. Đồ án UIT - Đánh giá hiệu năng microservices trên AWS EKS.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "🔴 RED Metrics — Request Rate, Error Rate, Duration",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "Total RPS",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"2..\"}[1m]))",
          "legendFormat": "Success RPS",
          "refId": "B"
        }
      ],
      "title": "📈 Throughput (RPS)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.005
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "Error Rate (5xx)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"4..\"}[1m])) / sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "4xx Rate",
          "refId": "B"
        }
      ],
      "title": "❌ Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "orange",
                "value": 100
              },
              {
                "color": "red",
                "value": 500
              }
            ]
          }
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.999, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P99.9",
          "refId": "D"
        }
      ],
      "title": "⏱️ Latency Percentiles (P50 / P95 / P99 / P99.9)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "id": 101,
      "title": "🔵 USE Metrics — Utilization, Saturation, Errors (Node Level)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "id": 4,
      "targets": [
        {
          "expr": "1 - avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) by (node)",
          "legendFormat": "CPU Usage — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "avg(rate(node_cpu_seconds_total{mode=\"steal\"}[1m])) by (node)",
          "legendFormat": "CPU Steal — {{ node }}",
          "refId": "B"
        }
      ],
      "title": "🖥️ CPU Utilization per Node",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "pps"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 10
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_packets_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "RX PPS — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_packets_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "TX PPS — {{ node }}",
          "refId": "B"
        }
      ],
      "title": "📦 Network PPS (eth0)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 10
      },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(node_netstat_Tcp_RetransSegs[10s])) by (node)",
          "legendFormat": "TCP Retransmit/s — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_receive_drop_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "RX Drop/s — {{ node }}",
          "refId": "B"
        }
      ],
      "title": "⚠️ TCP Retransmit & Packet Drop Rate",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "id": 102,
      "title": "🟡 Scenario 2 — Head-of-Line Blocking: Thread Pool & Little's Law",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 19
      },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=\"503\"}[1m])) by (service_name)",
          "legendFormat": "503 Rate (Pool Saturated) — {{ service_name }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total[1m])) by (service_name)",
          "legendFormat": "Total RPS — {{ service_name }}",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=\"503\"}[1m])) / sum(rate(http_server_request_count_total[1m])) * 100",
          "legendFormat": "503 % (Saturation Proxy)",
          "refId": "C"
        }
      ],
      "title": "🧵 Thread Pool Saturation (503 Rate Proxy)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 19
      },
      "id": 8,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total[1m])) * histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "N_predicted = λ × T (Little's Law)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total[1m])) * histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le))",
          "legendFormat": "N_approx (λ × P50) — add custom counter for exact N",
          "refId": "B"
        }
      ],
      "title": "📐 Little's Law Verification: N = λ × T",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 103,
      "title": "🟢 Scenario 1 — Microburst: PPS & TCP Analysis",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 28
      },
      "id": 9,
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_packets_total{device=\"eth0\"}[1s])) by (node)",
          "legendFormat": "RX PPS 1s — {{ node }}",
          "refId": "A"
        }
      ],
      "title": "🔥 Network RX PPS — 1s resolution (Microburst Detection)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_VICTORIAMETRICS}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 10,
      "targets": [
        {
          "expr": "sum(rate(node_context_switches_total[1m])) by (node)",
          "legendFormat": "Context Switches/s — {{ node }}",
          "refId": "A"
        }
      ],
      "title": "🔄 CPU Context Switches/s (Scenario 3)",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": [
    "microservices",
    "performance",
    "eks",
    "red",
    "use"
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_VICTORIAMETRICS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_VICTORIAMETRICS}"
        },
        "definition": "label_values(node_cpu_seconds_total, node)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(node_cpu_seconds_total, node)",
        "refresh": 2,
        "type": "query",
        "label": "Node"
      }
    ]
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "title": "Microservices Performance — RED+USE",
  "uid": "microservices-perf-red-use",
  "version": 1
}