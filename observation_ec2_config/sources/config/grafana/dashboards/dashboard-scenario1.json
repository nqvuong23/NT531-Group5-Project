{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Scenario 1 — Microburst Traffic & Congestion: TCP retransmit, packet drop, latency spike, error rate.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📡 Network Layer — PPS & Drops",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "RX Packets Per Second tại 1s resolution — dùng để detect microburst ngắn (50ms). Spike đột ngột = burst traffic.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 1 },
          "unit": "pps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_packets_total{device=\"eth0\"}[1s])) by (node)",
          "legendFormat": "RX PPS 1s — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_receive_packets_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "RX PPS 10s avg — {{ node }}",
          "refId": "B"
        }
      ],
      "title": "🔥 Network RX PPS — 1s vs 10s (Microburst Detection)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "Packet drop tuyệt đối và % drop rate. Drop > 1% = buffer overrun từ microburst.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Drop % — eth0" },
            "properties": [
              { "id": "unit", "value": "percent" },
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
              { "id": "custom.thresholdsStyle", "value": { "mode": "line" } }
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_drop_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "RX Drop/s — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_receive_drop_total{device=\"eth0\"}[1m])) / sum(rate(node_network_receive_packets_total{device=\"eth0\"}[1m])) * 100",
          "legendFormat": "Drop % — eth0",
          "refId": "B"
        }
      ],
      "title": "📉 Packet Drop Rate (Absolute & %)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "🔁 TCP Layer — Retransmit & Network Stats",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "TCP Retransmit rate. Spike = packet loss → TCP recovery → latency tăng. Ngưỡng alert: > 10/s.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 5 }, { "color": "red", "value": 10 }]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(node_netstat_Tcp_RetransSegs[10s])) by (node)",
          "legendFormat": "TCP Retransmit/s — {{ node }}",
          "refId": "A"
        }
      ],
      "title": "⚠️ TCP Retransmit Rate/s",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "Bytes throughput trên eth0. Kết hợp với PPS để tính average packet size (nhỏ = nhiều small packets = overhead).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "Bps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(rate(node_network_receive_bytes_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "RX Bytes/s — {{ node }}",
          "refId": "A"
        },
        {
          "expr": "sum(rate(node_network_transmit_bytes_total{device=\"eth0\"}[10s])) by (node)",
          "legendFormat": "TX Bytes/s — {{ node }}",
          "refId": "B"
        }
      ],
      "title": "🌐 Network Throughput (Bytes/s)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 102,
      "title": "⏱️ Application Layer — Latency & Error Rate",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "Latency percentiles toàn service. Microburst signature: P99/P99.9 spike mạnh, P50 tăng ít. Red line = 500ms alert threshold.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 50 }, { "color": "orange", "value": 100 }, { "color": "red", "value": 500 }]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 5,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P99",
          "refId": "C"
        },
        {
          "expr": "histogram_quantile(0.999, sum(rate(http_server_request_duration_seconds_bucket[1m])) by (le)) * 1000",
          "legendFormat": "P99.9",
          "refId": "D"
        }
      ],
      "title": "⏱️ Latency Percentiles — P50 / P95 / P99 / P99.9",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "Error rate theo status code. Microburst: 502 (upstream fail) + 504 (timeout). Alert nếu 5xx > 1%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.005 }, { "color": "red", "value": 0.01 }]
          }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"5..\"}[1m])) / sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "5xx Rate (all)",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=\"502\"}[1m])) / sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "502 Rate (Bad Gateway)",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=\"504\"}[1m])) / sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "504 Rate (Timeout)",
          "refId": "C"
        }
      ],
      "title": "❌ Error Rate — 5xx / 502 / 504",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "description": "Throughput toàn service. Trong microburst: total RPS tăng đột ngột, sau đó drop do errors.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 27 },
      "id": 7,
      "targets": [
        {
          "expr": "sum(rate(http_server_request_count_total[1m]))",
          "legendFormat": "Total RPS",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"2..\"}[1m]))",
          "legendFormat": "Success (2xx) RPS",
          "refId": "B"
        },
        {
          "expr": "sum(rate(http_server_request_count_total{http_response_status_code=~\"5..\"}[1m]))",
          "legendFormat": "Error (5xx) RPS",
          "refId": "C"
        }
      ],
      "title": "📈 Request Throughput — Total vs Success vs Error",
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["microservices", "scenario1", "microburst", "tcp", "network"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "DS_VICTORIAMETRICS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Datasource"
      },
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
        "definition": "label_values(node_cpu_seconds_total, node)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "node",
        "query": "label_values(node_cpu_seconds_total, node)",
        "refresh": 2,
        "type": "query",
        "label": "Node"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Scenario 1 — Microburst Traffic & Congestion",
  "uid": "scenario1-microburst",
  "version": 1
}
