# ============================================================
# .gitignore cho Terraform project
# ============================================================

# Terraform state files - quản lý qua S3 backend
*.tfstate
*.tfstate.*
.terraform.tfstate.lock.info

# Thư mục Terraform local
.terraform/
.terraform.lock.hcl

# Crash logs
crash.log
crash.*.log

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp

*.env
*.env.*
